# DeadMan Environment Configuration

# Database
DATABASE_URL=mongodb://localhost:27017/deadman

# Redis (for BullMQ background jobs)
REDIS_URL=redis://localhost:6379

# JWT & Session
JWT_SECRET=change-this-to-a-random-secret
SESSION_SECRET=change-this-to-a-random-secret

# Encryption (for storing integration secrets)
ENCRYPTION_SECRET=change-this-to-a-random-32-char-string

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# PagerDuty
PAGERDUTY_API_KEY=

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Email (for password reset, email verification)
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@deadman.dev

# Backend
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
