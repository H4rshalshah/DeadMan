# PulseOps — Local Development Environment Configuration
# Copy this file to .env and fill in your values

# ── App ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (MongoDB) ─────────────────────────────────
# Docker: mongodb://mongo:27017/pulseops
# Local:  mongodb://localhost:27017/pulseops
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/pulseops
MONGO_URI=mongodb://localhost:27017/pulseops
DATABASE_URL=

# ── Redis (for BullMQ job queue) ───────────────────────
# Docker: redis://redis:6379
# Local:  redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── URLs ───────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ── Secrets ────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production
SESSION_SECRET=change-this-to-a-random-secret-in-production
ENCRYPTION_SECRET=change-this-to-a-random-secret

# ── OAuth: Google ──────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── OAuth: GitHub ──────────────────────────────────────
# Create at: https://github.com/settings/developers
# Add callback URL: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ── Email (SMTP / Resend) ──────────────────────────────
# If not configured, reset links are logged to console in dev mode
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_SECURE=false
EMAIL_FROM=noreply@pulseops.dev

# ── Notifications ──────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
GITHUB_TOKEN=
